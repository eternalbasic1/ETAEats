          "name": "Advance Order Status — CONFIRMED → PREPARING",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/orders/restaurant/{{order_id}}/advance/", "host": ["{{base_url}}"], "path": ["api","v1","orders","restaurant","{{order_id}}","advance",""] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"status\": \"PREPARING\"\n}"
            }
          }
        },
        {
          "name": "Advance Order Status — PREPARING → READY",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/orders/restaurant/{{order_id}}/advance/", "host": ["{{base_url}}"], "path": ["api","v1","orders","restaurant","{{order_id}}","advance",""] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"status\": \"READY\"\n}"
            }
          }
        },
        {
          "name": "Advance Order Status — READY → PICKED_UP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/orders/restaurant/{{order_id}}/advance/", "host": ["{{base_url}}"], "path": ["api","v1","orders","restaurant","{{order_id}}","advance",""] },
            "body": {
