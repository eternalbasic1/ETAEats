    {
      "name": "💳 Payments",
      "item": [
        {
          "name": "Create Razorpay Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/payments/razorpay/order/", "host": ["{{base_url}}"], "path": ["api","v1","payments","razorpay","order",""] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"order_id\": \"{{order_id}}\"\n}"
            },
            "description": "Passenger only. Creates a Razorpay order for the given ETA Eats order. Returns razorpay_order_id, amount, currency, key_id for the client SDK."
          }
        },
        {
          "name": "Confirm Razorpay Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/payments/razorpay/confirm/", "host": ["{{base_url}}"], "path": ["api","v1","payments","razorpay","confirm",""] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"order_id\": \"{{order_id}}\",\n  \"razorpay_order_id\": \"{{razorpay_order_id}}\",\n  \"razorpay_payment_id\": \"{{razorpay_payment_id}}\",\n  \"razorpay_signature\": \"{{razorpay_signature}}\"\n}"
            },
            "description": "Verifies the Razorpay HMAC signature. On success sets payment_status=CAPTURED and advances order to CONFIRMED."
          }
        },
        {
          "name": "Razorpay Webhook  [public]",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Razorpay-Signature", "value": "{{razorpay_signature}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/payments/razorpay/webhook/", "host": ["{{base_url}}"], "path": ["api","v1","payments","razorpay","webhook",""] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"pay_test_123\",\n        \"order_id\": \"order_test_123\",\n        \"amount\": 26000,\n        \"currency\": \"INR\",\n        \"status\": \"captured\"\n      }\n    }\n  }\n}"
            },
            "description": "Called directly by Razorpay servers. Signature is verified in the service. Always returns 200."
          }
        }
      ]
    },

